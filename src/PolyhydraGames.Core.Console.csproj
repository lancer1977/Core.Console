<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<ImplicitUsings>true</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
	  <Compile Remove="Controls\**" />
	  <EmbeddedResource Remove="Controls\**" />
	  <None Remove="Controls\**" />
	</ItemGroup>

    <ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
        <PackageReference Include="PolyhydraGames.Core.Global" Version="1.0.3.11" />
		<ProjectReference Include="../../Core.Interfaces/Interfaces/PolyhydraGames.Core.Interfaces.csproj" />
        <PackageReference Include="PolyhydraGames.Core.IOC" Version="1.0.1.1" />
		<ProjectReference Include="../../Core/src/PolyhydraGames.Core.ReactiveUI/PolyhydraGames.Core.ReactiveUI.csproj" />
        <PackageReference Include="PolyhydraGames.Extensions" Version="2.1.1.79" />
        <PackageReference Include="ReactiveUI" Version="23.2.28" />
        <PackageReference Include="ReactiveUI.Fody" Version="19.5.41" />
        <PackageReference Include="Xamarin.Essentials" Version="1.8.1" />

		<PackageReference Include="Spectre.Console" Version="0.57.1" />
		<PackageReference Include="Spectre.Console.ImageSharp" Version="0.57.1" />
		<!-- ImageSharp 4.x requires a SixLabors license at build time; keep 3.x until licensing is configured. -->
		<PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
    </ItemGroup>

	<ItemGroup>
        <PackageReference Update="SonarAnalyzer.CSharp" Version="8.54.0.64047" />
    </ItemGroup>

	<ItemGroup>
	  <Folder Include="Services\Abstract\" />
